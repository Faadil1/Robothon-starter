<mujoco model="safety_gated_pusher">
  <option timestep="0.002" gravity="0 0 -9.81" />

  <default>
    <geom friction="1.0 0.005 0.0001" />
    <joint damping="1.0" />
  </default>

  <asset>
    <texture type="2d" name="grid" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2"
      width="512" height="512" />
    <material name="table_mat" texture="grid" texrepeat="4 4" reflectance="0.05" />
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" diffuse="1 1 1" specular="0.2 0.2 0.2" />
    <camera name="topdown" pos="0 0 2.2" euler="0 0 0" fovy="55" />
    <camera name="angled" pos="-1.0 -1.4 1.3" xyaxes="0.8 -0.6 0  0.3 0.5 0.8" />

    <!-- Table surface: group 1, collides with object only (not pusher) -->
    <geom name="table" type="box" size="0.75 0.6 0.02" pos="0 0 -0.02" material="table_mat"
      contype="1" conaffinity="4" />

    <!-- Goal/rescue zone (green, visual marker only, no collision). Placed
         at same y as the object's start so a direct push (no-go zone is
         far side, negative y) reaches it without crossing the no-go zone.
         Color strengthened for visibility (visual-only; position/size
         unchanged from original, so safety-logic geometry is identical). -->
    <geom name="goal_zone" type="box" size="0.12 0.12 0.001" pos="0.55 0.45 0.0011"
      rgba="0.15 0.95 0.25 0.75" contype="0" conaffinity="0" />

    <!-- Hazard / no-go zone (red, visual marker only, no collision).
         Placed at negative y so a straight push toward the goal (positive
         y side) never crosses it, but a push toward an "unsafe target" on
         the negative-y side does. Color strengthened for visibility
         (visual-only; position/size unchanged, so safety-logic geometry
         used by safety_gate.py is identical to before). -->
    <geom name="nogo_zone" type="box" size="0.5 0.15 0.001" pos="0.15 -0.25 0.0011"
      rgba="0.95 0.1 0.1 0.75" contype="0" conaffinity="0" />

    <!-- Pusher: slide-jointed paddle, position-controlled in x and y -->
    <body name="pusher" pos="-0.55 0.45 0.04">
      <joint name="pusher_x" type="slide" axis="1 0 0" range="-0.1 1.4" damping="8.0" />
      <joint name="pusher_y" type="slide" axis="0 1 0" range="-1.0 1.0" damping="8.0" />
      <geom name="pusher_geom" type="box" size="0.03 0.03 0.04" rgba="0.15 0.55 1.0 1" mass="2.0"
        contype="2" conaffinity="4" friction="0.02 0.005 0.0001" />
      <!-- Passive touch-sensor site: matches pusher_geom exactly, used only
           for read-only contact-force telemetry. No collision, no mass,
           no effect on dynamics -- purely observational. -->
      <site name="pusher_touch_site" type="box" size="0.03 0.03 0.04" rgba="0 0 0 0" />
    </body>

    <!-- Object: free box, the pushable item -->
    <body name="object" pos="-0.3 0.45 0.025">
      <joint name="object_free" type="free" />
      <geom name="object_geom" type="box" size="0.025 0.025 0.025" rgba="1.0 0.8 0.05 1" mass="0.3"
        contype="4" conaffinity="3" />
    </body>
  </worldbody>

  <actuator>
    <position name="act_x" joint="pusher_x" kp="400" />
    <position name="act_y" joint="pusher_y" kp="400" />
  </actuator>

  <!-- Passive telemetry only: reads contact-normal force magnitude at the
       pusher's touch site. Does not affect control, dynamics, or the
       safety gate -- read-only observation for Innovation/MuJoCo-Depth
       telemetry (contact_count, max contact force) surfaced in receipts. -->
  <sensor>
    <touch name="pusher_touch" site="pusher_touch_site" />
  </sensor>
</mujoco>
